access_token_expire_minutes=10080

# ── OpenAI ───────────────────────────────────────────────────────────────────
openai_api_key=sk-...

# ── ElevenLabs (voz para meditación) ─────────────────────────────────────────
elevenlabs_api_key=
elevenlabs_voice_id=21m00Tcm4TlvDq8ikWAM

# ── Philips Hue ──────────────────────────────────────────────────────────────
